{
  "description": "Security guardrails: block dangerous shell operations and detect prompt injection in web content",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PLUGIN_ROOT/hooks/block_rm.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 $CLAUDE_PLUGIN_ROOT/hooks/block_pipe_to_shell.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "WebFetch|mcp__browsermcp__.*|mcp__tavily__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $CLAUDE_PLUGIN_ROOT/hooks/detect_prompt_injection.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
